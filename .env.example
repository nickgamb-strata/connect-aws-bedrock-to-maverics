# Maverics Orchestrator image tag (set to match the version you loaded with `docker load`)
MAVERICS_IMAGE=maverics_base:v2026.03.2

# AWS region for Bedrock AgentCore. AgentCore is GA in us-east-1, us-west-2,
# ap-south-1, ap-southeast-1, ap-southeast-2, ap-northeast-1, eu-central-1, eu-west-1.
AWS_REGION=us-east-1

# Public Cloudflare Tunnel hostnames (set after `cloudflared tunnel create`).
# AgentCore reaches the gateway at https://${BEDROCK_GATEWAY_HOSTNAME}/mcp.
# The OIDC Provider must be reachable at https://${BEDROCK_AUTH_HOSTNAME}.
BEDROCK_GATEWAY_HOSTNAME=gateway.example.com
BEDROCK_AUTH_HOSTNAME=auth.example.com

# Bedrock OAuth client (matches the bedrock-agentcore client in the OIDC Provider).
# The client_secret value is the one you set in secrets.yaml under
# bedrock_agentcore.client_secret.
BEDROCK_OAUTH_CLIENT_ID=bedrock-agentcore
BEDROCK_OAUTH_CLIENT_SECRET=7p3K9vN2xQ8aL5jR4tH6mD1bF3sZcUgY

# AgentCore Gateway and target naming. Defaults work for the tutorial.
AGENTCORE_GATEWAY_NAME=maverics-gateway
AGENTCORE_TARGET_NAME=maverics-mcp
AGENTCORE_OAUTH_PROVIDER_NAME=maverics-oauth-provider

# Set after running scripts/aws-bootstrap.sh. The role ARN gateway uses to log
# and read its OAuth secret.
AGENTCORE_ROLE_ARN=
